import { test } from "@playwright/test";
import { faker } from "@faker-js/faker"

import PaginaCadastro from "../page-objects/PaginaCadastro";

test.describe("Pagina de Cadastro", () => {
    test("Deve realizar o cadastro de um usuário e depois acessar a página home com os dados criados", async ({ page }) => {

        const paginaCadastro = new PaginaCadastro(page);
        const nomeAleatorio = faker.person.fullName();
        const numeroCPF = faker.string.numeric(11);
        const telefoneAleatorio = faker.phone.number()
        const emailAleatorio = faker.internet.email()
        const senhaAleatoria = faker.internet.password()

        await paginaCadastro.visitarPaginaCadastro();
        await paginaCadastro.verificarPaginaDeCadastro();
        await paginaCadastro.preencherDadosPessoais(nomeAleatorio, new Date(), 'Masculino', numeroCPF, telefoneAleatorio);
        await paginaCadastro.preenchimentoDadoEndereçosESenha('Foz do Iguaçu', 'Paraná', emailAleatorio, senhaAleatoria);
        await paginaCadastro.assinandoTermosEConfirmando();
        await paginaCadastro.fazerLoginDeUsuarioNovo(emailAleatorio, senhaAleatoria);

    })
})



